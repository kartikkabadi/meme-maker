{
  "name": "agent-meme-maker",
  "version": "0.1.0",
  "description": "A meme editor for agents: template catalog, text overlay engine, CLI, and MCP server.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "meme": "dist/cli.js",
    "meme-maker-mcp": "dist/mcp.js"
  },
  "files": [
    "dist",
    "assets"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && npm run build:ui",
    "build:ui": "vite build ui",
    "dev:ui": "vite ui",
    "test": "vitest run",
    "lint": "eslint src test ui/src && prettier --check src test ui/src && tsc -p ui/tsconfig.json",
    "format": "prettier --write src test ui/src"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "commander": "^13.1.0",
    "opentype.js": "^2.0.0",
    "preact": "^10.29.7",
    "sharp": "^0.34.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@preact/preset-vite": "^2.10.6",
    "@types/node": "^20.17.0",
    "@types/opentype.js": "^1.3.10",
    "eslint": "^9.20.0",
    "prettier": "^3.5.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.24.0",
    "vite": "^6.4.3",
    "vitest": "^3.0.5"
  }
}
