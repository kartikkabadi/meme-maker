{
  "name": "agent-meme-maker",
  "version": "0.3.3",
  "private": true,
  "description": "Headless meme editor for agents: 609-template catalog (images + GIFs), deterministic text-overlay engine, CLI, MCP server, and local web UI.",
  "keywords": [
    "meme",
    "meme-generator",
    "mcp",
    "mcp-server",
    "cli",
    "agent",
    "ai",
    "image",
    "gif",
    "sharp",
    "headless"
  ],
  "author": "Kartik Kabadi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kartikkabadi/meme-maker.git"
  },
  "bugs": {
    "url": "https://github.com/kartikkabadi/meme-maker/issues"
  },
  "homepage": "https://github.com/kartikkabadi/meme-maker#readme",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "meme": "dist/cli.js",
    "meme-maker-mcp": "dist/mcp.js"
  },
  "files": [
    "dist",
    "assets",
    "!**/.gitkeep",
    "NOTICE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && npm run build:ui",
    "build:ui": "vite build ui",
    "dev:ui": "vite ui",
    "ui": "node dist/cli.js ui",
    "ui:portless": "node scripts/portless.js",
    "build:manifest": "tsx scripts/build-manifest.ts",
    "build:thumbs": "tsx scripts/build-thumbs.ts",
    "report:assets": "tsx scripts/asset-size-report.ts",
    "build:slim-tarball": "tsx scripts/pack-slim.ts",
    "test": "vitest run",
    "benchmark": "tsx scripts/benchmark.ts",
    "load-test": "tsx scripts/load-test.ts",
    "lint": "eslint src test scripts ui/src && prettier --check src test scripts ui/src && tsc -p ui/tsconfig.json",
    "format": "prettier --write src test scripts ui/src"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "commander": "^13.1.0",
    "opentype.js": "^2.0.0",
    "preact": "^10.29.7",
    "sharp": "^0.34.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@preact/preset-vite": "^2.10.6",
    "@types/node": "^20.17.0",
    "@types/opentype.js": "^1.3.10",
    "eslint": "^9.20.0",
    "portless": "^0.15.1",
    "prettier": "^3.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.24.0",
    "vite": "^6.4.3",
    "vitest": "^3.0.5"
  }
}
